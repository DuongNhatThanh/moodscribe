# Supabase project URL — safe to expose publicly.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — safe to expose publicly.
# Row Level Security enforces data access; the anon key alone grants nothing beyond RLS policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic API key — server-side only. Never prefix this with NEXT_PUBLIC_.
# Exposing it would allow anyone to call the Claude API on your behalf.
ANTHROPIC_API_KEY=
